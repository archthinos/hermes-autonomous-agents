# Hermes Autonomous Multi-Agent System - Environment Variables
# Copy this file to .env and fill in your values

# ==================== Database ====================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# Railway will auto-generate this when you add PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/hermes_autonomous

# ==================== Redis ====================
# Redis connection string
# Format: redis://[[username]:[password]]@host:port/database
# Railway will auto-generate this when you add Redis
REDIS_URL=redis://localhost:6379/0

# ==================== Telegram ====================
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Your Railway public URL (for webhook)
# Format: https://your-project-name.up.railway.app
TELEGRAM_WEBHOOK_URL=https://hermes-autonomous-agents.up.railway.app

# Optional: Webhook port (Railway sets PORT automatically)
# PORT=8080

# ==================== LLM Providers ====================
# Anthropic (Primary)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (Optional - for embeddings or fallback)
OPENAI_API_KEY=sk-...

# OpenRouter (Optional - alternative LLM provider)
OPENROUTER_API_KEY=sk-or-...

# ==================== Optional Services ====================
# Browserbase (Browser automation in cloud)
BROWSERBASE_API_KEY=...
BROWSERBASE_PROJECT_ID=...

# Exa (Web search API)
EXA_API_KEY=...

# Firecrawl (Web scraping)
FIRECRAWL_API_KEY=...

# ==================== Configuration ====================
# Daily API budget (USD)
DAILY_BUDGET=50.0

# Max notifications per day
MAX_NOTIFICATIONS_PER_DAY=3

# Orchestrator interval (hours)
ORCHESTRATOR_INTERVAL_HOURS=4

# ==================== Logging ====================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path (optional)
LOG_FILE=/var/log/hermes/autonomous.log

# ==================== Timezone ====================
# Your timezone (for scheduling)
TZ=Europe/Bratislava

# ==================== Development ====================
# Environment: development, production
ENVIRONMENT=production

# Debug mode (true/false)
DEBUG=false
